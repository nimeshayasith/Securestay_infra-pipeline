# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files
*.tfplan
tfplan

# Terraform working directories
**/.terraform/
**/.terraform.lock.hcl

# Terraform variable files that may contain secrets
*.auto.tfvars
*.auto.tfvars.example
# terraform.tfvars is committed — it contains only non-secret values

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo

# AWS credentials
.aws/

# Scripts temp files
*.sh.log
